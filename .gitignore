# private fake-book PDFs — the owner's own files, embedded into the image at
# build time (see Dockerfile). Never committed; the dir is kept via .gitkeep.
/books/*
!/books/.gitkeep

# Hand-made MusicXML charts — copyrighted content, same as books/. Copied into
# the image by the Dockerfile; see charts/README.md.
charts/*
!charts/README.md
